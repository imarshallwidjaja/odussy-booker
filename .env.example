PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
FILM_IDS=HO00000546,HO00000547
INGEST_TOKEN=replace-with-a-long-random-token

POLL_INTERVAL_MS=900000
POLL_COOLDOWN_MS=900000
PROVIDER_TIMEOUT_MS=30000

LUMOS_FILM_URL=https://web.imaxmelbourne.com.au/films/HO00000547
# Optional HTTP proxy for the protected Scrapling preview fallback.
CF_ACQUIRE_PROXY=
LUMOS_PREVIEW_CONCURRENCY=2
LUMOS_PREVIEW_SESSION_BUDGET=12
LUMOS_PREVIEW_COOLDOWN_MS=900000
LUMOS_PREVIEW_TIMEOUT_MS=60000
# After this long with continuous upstream blocks, exact preview parks instead of backing off further.
LUMOS_PREVIEW_PARK_AFTER_MS=172800000
# While parked, one probe is allowed per park window.
LUMOS_PREVIEW_PARK_DURATION_MS=43200000
LUMOS_ALLOWED_HOSTS=

RESEND_API_KEY=
ALERT_FROM=
EMAIL_DELIVERY_TIMEOUT_MS=30000
OUTBOX_BATCH_SIZE=25
CONFIRMATION_COOLDOWN_MS=900000
PENDING_SUBSCRIPTIONS_PER_EMAIL=3

# Enable only in production behind Railway or another trusted proxy that overwrites X-Real-IP.
TRUST_PROXY=false

DEV_SAMPLE_DATA=false
